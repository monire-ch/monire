<div
  id="nav-backdrop"
  class="pointer-events-none fixed top-0 right-0 bottom-0 left-0 z-[9998] h-full w-full bg-black/50 opacity-0 transition-opacity lg:hidden"
  aria-hidden="true">
</div>

<button
  type="button"
  id="nav-toggle"
  class="relative z-[10001] -translate-x-2 inline-flex items-center justify-center gap-2 rounded-md p-2 text-[var(--color-link-dark-bg)] hover:bg-transparent hover:text-[var(--color-link-dark-bg-hover)] lg:hidden"
  aria-controls="nav-menu"
  aria-label="Toggle navigation"
  aria-expanded="false"
  style="position: relative; z-index: 10001;">
  <svg
    id="hamburger-icon"
    class="h-6 w-6"
    width="24"
    height="24"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round">
    <line x1="3" y1="6" x2="21" y2="6"></line>
    <line x1="3" y1="12" x2="21" y2="12"></line>
    <line x1="3" y1="18" x2="21" y2="18"></line>
  </svg>
  <svg
    id="close-icon"
    class="hidden h-6 w-6"
    width="24"
    height="24"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round">
    <path d="M18 6 6 18"></path>
    <path d="m6 6 12 12"></path>
  </svg>
</button>

<script>
  function initMobileMenu() {
    const toggleBtn = document.getElementById("nav-toggle");
    const navMenu = document.getElementById("nav-menu");
    const backdrop = document.getElementById("nav-backdrop");
    const hamburgerIcon = document.getElementById("hamburger-icon");
    const closeIcon = document.getElementById("close-icon");

    if (!toggleBtn || !navMenu || !backdrop) return;

    const isMobile = () => window.matchMedia("(max-width: 1023px)").matches;

    const parseDurationMs = (value: string, fallback: number) => {
      const normalized = String(value || "").trim();
      if (!normalized) return fallback;
      if (normalized.endsWith("ms")) {
        const ms = parseFloat(normalized.slice(0, -2));
        return Number.isFinite(ms) ? ms : fallback;
      }
      if (normalized.endsWith("s")) {
        const s = parseFloat(normalized.slice(0, -1));
        return Number.isFinite(s) ? s * 1000 : fallback;
      }
      const raw = parseFloat(normalized);
      return Number.isFinite(raw) ? raw : fallback;
    };

    const getCloseDurationMs = () => {
      const rootStyle = getComputedStyle(document.documentElement);
      const panelMs = parseDurationMs(
        rootStyle.getPropertyValue("--nav-menu-panel-duration"),
        720,
      );
      const fadeMs = parseDurationMs(
        rootStyle.getPropertyValue("--nav-menu-fade-duration"),
        520,
      );
      return Math.max(panelMs, fadeMs) + 40;
    };

    // --- scroll lock (only when menu actually opens on mobile). Needed for close button to be visible ---
    let scrollY = 0;
    let isLocked = false;

    const lockScroll = () => {
      if (isLocked) return;
      scrollY = window.scrollY || 0;
      document.body.style.position = "fixed";
      document.body.style.top = `-${scrollY}px`;
      document.body.style.left = "0";
      document.body.style.right = "0";
      document.body.style.width = "100%";
      isLocked = true;
    };

    const unlockScroll = (restore = true) => {
      if (!isLocked) return;

      const html = document.documentElement;
      const prevScrollBehavior = html.style.scrollBehavior;
      html.style.scrollBehavior = "auto";

      document.body.style.position = "";
      document.body.style.top = "";
      document.body.style.left = "";
      document.body.style.right = "";
      document.body.style.width = "";

      if (restore) window.scrollTo(0, scrollY);

      html.style.scrollBehavior = prevScrollBehavior;
      isLocked = false;
    };

    // pending hash (mobile only)
    let pendingHash = "";

    const scrollToHash = (hash) => {
      if (!hash || hash === "#") return;
      const el = document.querySelector(hash);
      if (!el) return;
      el.scrollIntoView({ behavior: "smooth", block: "start" });
    };

    let closeTimer = 0;

    const openMenu = () => {
      if (!isMobile()) return;
      window.clearTimeout(closeTimer);

      navMenu.classList.add("open");

      backdrop.classList.remove("opacity-0", "pointer-events-none");
      backdrop.classList.add("opacity-100", "pointer-events-auto");

      hamburgerIcon?.classList.add("hidden");
      closeIcon?.classList.remove("hidden");
      toggleBtn.setAttribute("aria-expanded", "true");

      lockScroll();
    };

    const closeMenu = () => {
      if (!isMobile()) return;
      window.clearTimeout(closeTimer);

      navMenu.classList.remove("open");

      backdrop.classList.remove("opacity-100");
      backdrop.classList.add("opacity-0");

      hamburgerIcon?.classList.remove("hidden");
      closeIcon?.classList.add("hidden");
      toggleBtn.setAttribute("aria-expanded", "false");

      closeTimer = window.setTimeout(() => {
        backdrop.classList.remove("pointer-events-auto");
        backdrop.classList.add("pointer-events-none");

        // If user clicked an anchor, do NOT restore old scroll; go to target instead.
        const shouldRestore = !pendingHash;
        unlockScroll(shouldRestore);

        if (pendingHash) {
          const hash = pendingHash;
          pendingHash = "";

          // update URL without immediate browser jump (we’ll scroll ourselves)
          history.pushState(null, "", hash);

          requestAnimationFrame(() => scrollToHash(hash));
        }
      }, getCloseDurationMs());
    };

    // Toggle button (mobile only)
    toggleBtn.addEventListener("click", (e) => {
      if (!isMobile()) return;
      e.preventDefault();
      e.stopPropagation();
      navMenu.classList.contains("open") ? closeMenu() : openMenu();
    });

    // Backdrop click (mobile only)
    backdrop.addEventListener("click", (e) => {
      if (!isMobile()) return;
      e.preventDefault();
      e.stopPropagation();
      closeMenu();
    });

    // Nav link clicks:
    // - Desktop: do nothing, let browser handle anchors normally
    // - Mobile: if same-page hash, intercept and scroll after closing
    navMenu.querySelectorAll("a.nav-link").forEach((link) => {
      link.addEventListener("click", (e) => {
        if (!isMobile()) return;

        const url = new URL(link.href, window.location.href);
        const isSamePage =
          url.origin === window.location.origin &&
          url.pathname === window.location.pathname;

        if (isSamePage && url.hash) {
          e.preventDefault(); // prevent jump while body is fixed
          pendingHash = url.hash;
          closeMenu();
          return;
        }

        // Normal navigation to another page: allow default, but close menu + unlock
        // so the page isn't left locked if navigation is slow.
        pendingHash = "";
        closeMenu();
      });
    });

    // Close menu on resize to desktop
    window.addEventListener("resize", () => {
      if (!isMobile()) {
        // If we were open/locked and user resized, clean up.
        navMenu.classList.remove("open");
        backdrop.classList.remove("opacity-100", "pointer-events-auto");
        backdrop.classList.add("opacity-0", "pointer-events-none");
        hamburgerIcon?.classList.remove("hidden");
        closeIcon?.classList.add("hidden");
        toggleBtn.setAttribute("aria-expanded", "false");
        unlockScroll(true);
        pendingHash = "";
      }
    });

    document.addEventListener("keydown", (e) => {
      if (!isMobile()) return;
      if (e.key === "Escape" && navMenu.classList.contains("open")) closeMenu();
    });
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initMobileMenu);
  } else {
    initMobileMenu();
  }
</script>

<style>
  #nav-backdrop {
    transition-duration: var(--nav-menu-fade-duration);
    transition-timing-function: var(--nav-menu-motion-ease);
  }
</style>